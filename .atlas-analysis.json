  "keyFeatures": [
    "Multiple OCR modes (raw text, structured MyBillBook, normalized India GST)",
    "Intelligent reconciliation engine that validates totals and tax calculations",
    "PDF and image support via OpenRouter vision models",
    "LangFuse review tool for debugging OCR responses",
    "Strict JSON output enforcement",
    "India GST-specific features (CGST/SGST/IGST, HSN codes)",
    "Automatic detection of price modes (with/without tax)",
    "Line-item discount and tax breakdown"
  ],
  "publicApiSurface": [
    "POST /api/ocr - Raw text OCR extraction",
    "POST /api/ocr-structured - MyBillBook schema extraction",
    "POST /api/ocr-structured-v4 - Normalized India GST with reconciliation",
    "GET /api/models - Available OpenRouter models",
    "reconcileV4() - Reconciliation engine function",
    "V4Doc type - Document schema interface",
    "V4Item type - Line item schema interface"
  ]
